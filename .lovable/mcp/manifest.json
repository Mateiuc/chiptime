{
  "version": 1,
  "sdk_version": "0.22.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://sgfpvrfjgzwsjwduibhm.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "chiptime-mcp",
      "version": "0.1.0",
      "title": "ChipTime MCP"
    },
    "tools": [
      {
        "name": "list_clients",
        "title": "List clients",
        "description": "List clients in the signed-in user's ChipTime workspace, optionally filtered by a name/email substring search.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Case-insensitive substring match against name, email, or company."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "description": "Max rows (default 50)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_tasks",
        "title": "List tasks",
        "description": "List work tasks in the user's ChipTime workspace. Filter by status and/or client. Sessions and photos are omitted; use get_task for details.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "pending",
                "in-progress",
                "paused",
                "completed",
                "billed",
                "paid"
              ],
              "description": "Filter by task status."
            },
            "clientId": {
              "type": "string",
              "description": "Filter to tasks for a specific client id."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "description": "Max rows (default 50)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_task",
        "title": "Get task detail",
        "description": "Fetch a single ChipTime task with its work sessions, parts, jobs, and billing status. Photo binary data is omitted.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string",
              "minLength": 1,
              "description": "Task id (from list_tasks)."
            }
          },
          "required": [
            "taskId"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_schedule",
        "title": "List scheduled jobs",
        "description": "List upcoming or open ChipTime schedule entries (jobs planned but not yet started).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "scheduled",
                "started",
                "cancelled"
              ],
              "description": "Filter by schedule status (default: scheduled)."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
